{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pilot's Desk",
  "version": "0.4.3",
  "identifier": "com.cosauce.pilotsdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pilot's Desk - Sales Assistant",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1280,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "scripts/**/*",
      "models/**/*",
      "whisper-bin/**/*"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "en-US"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "publisher": "CoSauce",
    "copyright": "Copyright © 2026 CoSauce",
    "category": "Productivity",
    "shortDescription": "Voice-responsive sales assistance for BPO agents",
    "longDescription": "Pilot's Desk provides real-time script guidance, live coaching, and compliance monitoring for sales agents. Features voice-triggered navigation, interactive widgets, and local transcription for privacy."
  }
}
