{
  "version": "2.0.0",
  "client_id": "SKY_TV_NZ",
  "name": "Sky TV NZ - Main Sales Pitch v2",
  "description": "Enhanced outbound sales script with BANT qualification, comprehensive objection handling, and compliance-first approach",
  "variables": [
    "customer_name",
    "agent_name",
    "current_plan",
    "fav_sport",
    "fav_team",
    "callback_date",
    "callback_time",
    "partner_name"
  ],
  "nodes": [
    {
      "id": "greeting_01",
      "type": "SCRIPT",
      "config": {
        "text": "Hi {{customer_name}}, this is {{agent_name}} calling from Sky TV New Zealand. How are you doing today?",
        "keywords": ["hi", "hello", "sky tv", "calling"],
        "wait_for_response": true,
        "display_notes": "SA AGENTS: Warm, friendly tone. Slow down your natural pace for NZ customers. Pronounce 'Sky' clearly."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["good", "fine", "well", "great", "alright"],
          "next_node": "compliance_recording_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["not interested", "no thanks", "remove me", "don't call"],
          "next_node": "objection_not_interested_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["busy", "no time", "bad time", "can't talk"],
          "next_node": "objection_busy_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "INTENT",
          "value": "Positive",
          "next_node": "compliance_recording_01",
          "confidence_threshold": 0.6
        }
      ]
    },
    {
      "id": "compliance_recording_01",
      "type": "COMPLIANCE",
      "config": {
        "text": "Great! Before we continue, I need to let you know this call is being recorded for quality and training purposes. Are you okay with that?",
        "keywords": ["recording", "consent", "quality", "training"],
        "verbatim_match": 0.95,
        "on_skip": "WARNING",
        "alert_message": "COMPLIANCE: Recording consent is MANDATORY in NZ before proceeding",
        "wait_for_response": true,
        "display_notes": "CRITICAL: MUST get verbal consent. NZ Privacy Act requirement. Do not skip."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "sure", "okay", "fine", "no problem", "go ahead"],
          "next_node": "needs_discovery_intro",
          "confidence_threshold": 0.8
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "don't want", "not okay", "prefer not"],
          "next_node": "compliance_decline_01",
          "confidence_threshold": 0.8
        }
      ]
    },
    {
      "id": "compliance_decline_01",
      "type": "SCRIPT",
      "config": {
        "text": "I completely understand. Unfortunately, I can't proceed without recording consent as it's a regulatory requirement. Would you prefer I call you back at a better time when you're comfortable with it?",
        "keywords": ["can't proceed", "regulatory", "call back"],
        "wait_for_response": true,
        "display_notes": "Recording consent declined. Offer callback option."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "sure", "call back", "later"],
          "next_node": "callback_schedule_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "not interested", "don't call"],
          "next_node": "polite_close_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "needs_discovery_intro",
      "type": "SCRIPT",
      "config": {
        "text": "Perfect, thanks {{customer_name}}. I'm reaching out because we have some exciting packages right now with premium sports and entertainment. Quick question - are you currently watching any sports?",
        "keywords": ["sports", "packages", "entertainment", "watching"],
        "wait_for_response": true,
        "display_notes": "Start NEED qualification. Listen for: rugby, cricket, football, netball, basketball."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["rugby", "all blacks", "super rugby", "crusaders", "blues", "highlanders"],
          "next_node": "sport_pitch_rugby",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["cricket", "black caps", "test match"],
          "next_node": "sport_pitch_cricket",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["football", "soccer", "premier league", "champions league"],
          "next_node": "sport_pitch_football",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "not really", "don't watch", "not into sports"],
          "next_node": "movies_pitch_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["netflix", "streaming", "already have"],
          "next_node": "objection_already_streaming_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "INTENT",
          "value": "Positive",
          "next_node": "sport_pitch_generic",
          "confidence_threshold": 0.6
        }
      ]
    },
    {
      "id": "sport_pitch_rugby",
      "type": "SCRIPT_AND_WIDGET",
      "config": {
        "text": "Fantastic! Rugby fans absolutely love our Sport package. You get every All Blacks match, all Super Rugby games, and exclusive behind-the-scenes content you can't get anywhere else. Let me show you what's included.",
        "widget": "package_calculator",
        "keywords": ["all blacks", "super rugby", "sport package", "exclusive"],
        "auto_trigger": {
          "listen_for": ["rugby", "all blacks", "super rugby"],
          "action": "enable_sport_package"
        },
        "display_notes": "Widget auto-enables Sport package. Emphasize exclusivity (not on streaming)."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["sounds good", "interested", "yes", "tell me more"],
          "next_node": "bundle_upsell_sport",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["expensive", "cost", "price", "how much"],
          "next_node": "price_reveal_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["think about it", "not sure", "maybe later"],
          "next_node": "objection_timing_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "sport_pitch_cricket",
      "type": "SCRIPT_AND_WIDGET",
      "config": {
        "text": "Excellent! Cricket season is massive right now. Our Sport package gives you every Black Caps match - tests, ODIs, T20s - plus IPL, The Ashes, and all the big tournaments. Let me show you the details.",
        "widget": "package_calculator",
        "keywords": ["black caps", "cricket", "sport package", "ipl"],
        "auto_trigger": {
          "listen_for": ["cricket", "black caps"],
          "action": "enable_sport_package"
        },
        "display_notes": "Widget auto-enables Sport package. Cricket is huge in NZ - emphasize comprehensive coverage."
      },
      "transitions": [
        {
          "trigger_type": "INTENT",
          "value": "Positive",
          "next_node": "bundle_upsell_sport",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["expensive", "cost", "price"],
          "next_node": "price_reveal_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "sport_pitch_football",
      "type": "SCRIPT_AND_WIDGET",
      "config": {
        "text": "Perfect! We've got Premier League, La Liga, Champions League, Europa League - basically every major football competition. Our Sport package is a must-have for football fans in New Zealand.",
        "widget": "package_calculator",
        "keywords": ["premier league", "football", "sport package", "champions league"],
        "auto_trigger": {
          "listen_for": ["football", "soccer", "premier league"],
          "action": "enable_sport_package"
        },
        "display_notes": "Widget auto-enables Sport package. Football fans are passionate - emphasize breadth."
      },
      "transitions": [
        {
          "trigger_type": "INTENT",
          "value": "Positive",
          "next_node": "bundle_upsell_sport",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["expensive", "cost", "price"],
          "next_node": "price_reveal_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "sport_pitch_generic",
      "type": "SCRIPT_AND_WIDGET",
      "config": {
        "text": "Great! Our Sport package covers rugby, cricket, football, netball, basketball - basically every major sport you can think of. All live, all in HD. Let me show you what's included.",
        "widget": "package_calculator",
        "keywords": ["sport package", "coverage", "live", "hd"],
        "auto_trigger": {
          "listen_for": ["yes", "sure", "interested"],
          "action": "enable_sport_package"
        },
        "display_notes": "Generic sport pitch. Let customer ask about specific sports if interested."
      },
      "transitions": [
        {
          "trigger_type": "INTENT",
          "value": "Positive",
          "next_node": "bundle_upsell_sport",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["expensive", "cost", "price"],
          "next_node": "price_reveal_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "bundle_upsell_sport",
      "type": "SCRIPT",
      "config": {
        "text": "Awesome! Now, a lot of our Sport customers also grab the Movies package because when you bundle any two packages together, you save an extra $5 per month. Would you be interested in adding Movies as well?",
        "keywords": ["bundle", "movies", "save", "$5"],
        "wait_for_response": true,
        "display_notes": "Upsell attempt. Bundle discount: 2 packages = $5 off, 3 packages = $10 off."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "sure", "sounds good", "tell me more"],
          "next_node": "movies_add_bundle",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "just sport", "not interested"],
          "next_node": "soft_close_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "movies_add_bundle",
      "type": "SCRIPT_AND_WIDGET",
      "config": {
        "text": "Excellent choice! Our Movies package includes the latest blockbusters, MGM, Rialto, and Warner Bros channels. You'll have hundreds of movies on demand. Let me update that for you.",
        "widget": "package_calculator",
        "keywords": ["movies", "blockbusters", "on demand"],
        "auto_trigger": {
          "listen_for": ["movies", "add"],
          "action": "enable_movies_package"
        },
        "display_notes": "Widget auto-enables Movies package AND applies $5 bundle discount."
      },
      "transitions": [
        {
          "trigger_type": "AUTO",
          "next_node": "soft_close_01"
        }
      ]
    },
    {
      "id": "movies_pitch_01",
      "type": "SCRIPT_AND_WIDGET",
      "config": {
        "text": "No worries about sports. How about movies? Our Movies package gives you the latest blockbusters, premium channels like MGM and Rialto, and hundreds of movies on demand. Perfect for movie nights at home.",
        "widget": "package_calculator",
        "keywords": ["movies", "blockbusters", "channels", "on demand"],
        "auto_trigger": {
          "listen_for": ["movies", "films"],
          "action": "enable_movies_package"
        },
        "display_notes": "Movies package pitch. Alternative path for non-sports fans."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "interested", "sounds good"],
          "next_node": "soft_close_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["not interested", "no thanks"],
          "next_node": "soho_pitch_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["expensive", "price", "cost"],
          "next_node": "price_reveal_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "soho_pitch_01",
      "type": "SCRIPT_AND_WIDGET",
      "config": {
        "text": "I understand. What about quality drama and lifestyle content? Our SoHo package has award-winning series like Succession, The White Lotus, and premium documentaries. Think of it as curated, high-quality entertainment.",
        "widget": "package_calculator",
        "keywords": ["soho", "drama", "documentaries", "series"],
        "auto_trigger": {
          "listen_for": ["soho", "drama", "series"],
          "action": "enable_soho_package"
        },
        "display_notes": "SoHo package pitch. Last option before soft close or objection handling."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "interested", "sounds good"],
          "next_node": "soft_close_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["not interested", "no thanks"],
          "next_node": "objection_not_interested_02",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "soft_close_01",
      "type": "SCRIPT",
      "config": {
        "text": "So based on what we've discussed, does this sound like something that would work well for you and your household?",
        "keywords": ["sound like", "work well", "household"],
        "wait_for_response": true,
        "display_notes": "SOFT CLOSE: Trial close before price reveal. Gauge true interest. Listen carefully."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "sounds good", "definitely", "think so"],
          "next_node": "qualify_authority_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["maybe", "not sure", "need to think"],
          "next_node": "objection_timing_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["partner", "wife", "husband", "spouse"],
          "next_node": "objection_partner_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "not interested"],
          "next_node": "objection_not_interested_02",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "qualify_authority_01",
      "type": "SCRIPT",
      "config": {
        "text": "Great! Just to confirm, are you the account holder for your household, or would you need to check with anyone else before we proceed?",
        "keywords": ["account holder", "check with", "household"],
        "wait_for_response": true,
        "display_notes": "AUTHORITY qualification (BANT). If not decision-maker, offer callback or partner invite."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "i am", "me", "just me", "my account"],
          "next_node": "price_reveal_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["partner", "wife", "husband", "spouse", "check with"],
          "next_node": "objection_partner_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "price_reveal_01",
      "type": "SCRIPT",
      "config": {
        "text": "Perfect! Based on what you've selected, your total comes to [PRICE FROM WIDGET] per month. And right now, we're running a promotion - your first month is 50% off, so you can try it for half price.",
        "keywords": ["price", "month", "discount", "50% off", "promotion"],
        "wait_for_response": true,
        "display_notes": "CRITICAL: Price shown in widget. Emphasize 50% first month discount. If bundle selected, mention bundle savings."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["sounds good", "let's do it", "sign me up", "okay"],
          "next_node": "compliance_parental_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["expensive", "too much", "can't afford", "pricey"],
          "next_node": "objection_price_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["think about it", "maybe later", "not sure"],
          "next_node": "objection_timing_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "objection_not_interested_01",
      "type": "SCRIPT",
      "config": {
        "text": "I totally understand, {{customer_name}}. Can I ask - is it because you're happy with what you've got, or just not the right time? I'd hate for you to miss out on this promotion.",
        "keywords": ["understand", "happy with", "right time", "promotion"],
        "wait_for_response": true,
        "display_notes": "Early 'not interested' objection. Probe gently for real reason. Don't be pushy."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["timing", "later", "busy", "not now"],
          "next_node": "objection_timing_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["happy", "netflix", "streaming", "have something"],
          "next_node": "objection_already_streaming_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["not interested", "no thanks", "remove me"],
          "next_node": "polite_close_01",
          "confidence_threshold": 0.8
        }
      ]
    },
    {
      "id": "objection_not_interested_02",
      "type": "SCRIPT",
      "config": {
        "text": "Fair enough, {{customer_name}}. I appreciate your honesty. Just one last thing - would you be open to a quick callback in a few months when we have new promotions? I promise I won't take up much of your time.",
        "keywords": ["appreciate", "callback", "few months", "new promotions"],
        "wait_for_response": true,
        "display_notes": "Later 'not interested' objection. Last attempt - offer future callback."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "sure", "okay", "fine"],
          "next_node": "callback_schedule_01",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "don't call", "not interested"],
          "next_node": "polite_close_01",
          "confidence_threshold": 0.8
        }
      ]
    },
    {
      "id": "objection_price_01",
      "type": "SCRIPT",
      "config": {
        "text": "I totally get that budget matters. Here's how I look at it - you're getting [LIST PACKAGES] for less than the cost of two coffees a day. Plus, with the 50% off first month, you can try it out with almost no commitment. Does that sound more reasonable?",
        "keywords": ["budget", "affordable", "two coffees", "50% off", "no commitment"],
        "wait_for_response": true,
        "display_notes": "Price objection handler. Break down to daily cost. Emphasize trial offer and value."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["okay", "makes sense", "fair enough", "let's do it"],
          "next_node": "compliance_parental_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["still expensive", "still too much", "can't afford"],
          "next_node": "objection_price_downgrade",
          "confidence_threshold": 0.7
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["think about it", "maybe later"],
          "next_node": "objection_timing_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "objection_price_downgrade",
      "type": "SCRIPT",
      "config": {
        "text": "No problem at all. Would it help if we just started with one package instead? For example, just Sport at $29.99, or Movies at $19.99? That way you can see the value before adding more.",
        "keywords": ["one package", "sport", "movies", "see the value"],
        "wait_for_response": true,
        "display_notes": "Downgrade offer. Reduce commitment to single package. Still attempt close."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "okay", "just sport", "just movies"],
          "next_node": "compliance_parental_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "still not", "can't"],
          "next_node": "callback_schedule_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "objection_timing_01",
      "type": "SCRIPT",
      "config": {
        "text": "I completely understand you want to think about it, {{customer_name}}. Just so you know, this 50% off first month promotion ends this Friday, so if you're interested at all, now's definitely the best time. Can I at least get you started today?",
        "keywords": ["think about it", "promotion ends", "this friday", "best time"],
        "wait_for_response": true,
        "display_notes": "Timing objection. Create urgency with promotion deadline. If they resist, offer callback."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["okay", "let's do it", "go ahead", "sure"],
          "next_node": "compliance_parental_01",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "later", "call back", "not now"],
          "next_node": "callback_schedule_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "objection_busy_01",
      "type": "SCRIPT",
      "config": {
        "text": "I completely understand you're busy, {{customer_name}}. This will only take 2 minutes, and I think you'll genuinely want to hear about this offer. Can I have just 90 seconds of your time?",
        "keywords": ["busy", "2 minutes", "90 seconds", "want to hear"],
        "wait_for_response": true,
        "display_notes": "Busy objection. Be respectful of their time. Quantify the ask (90 seconds)."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["okay", "fine", "go ahead", "quick"],
          "next_node": "needs_discovery_intro",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "not now", "call later", "busy"],
          "next_node": "callback_schedule_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "objection_already_streaming_01",
      "type": "SCRIPT",
      "config": {
        "text": "That's great you've got Netflix or similar. Here's the thing though - we have exclusive live sports and premium channels you can't get on streaming services. All Blacks games, Premier League, latest movies. It's actually complementary to what you already have. Would that be useful to you?",
        "keywords": ["exclusive", "live sports", "can't get on streaming", "complementary"],
        "wait_for_response": true,
        "display_notes": "Already have streaming objection. Emphasize EXCLUSIVITY (live sports, premium channels). Position as additive."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["yes", "useful", "makes sense", "interested"],
          "next_node": "sport_pitch_generic",
          "confidence_threshold": 0.6
        },
        {
          "trigger_type": "KEYWORD",
          "value": ["no", "not interested", "happy with what I have"],
          "next_node": "polite_close_01",
          "confidence_threshold": 0.7
        }
      ]
    },
    {
      "id": "objection_partner_01",
      "type": "SCRIPT",
      "config": {
        "text": "That's very sensible to check with your partner first. Would it help if I gave you a quick summary you can share with them? Or I'm happy to call back when you're both available - what works best for you?",
        "keywords": ["partner", "summary", "call back", "both available"],
        "wait_for_response": true,
        "display_notes": "Partner objection. Don't pressure solo decision. Offer summary OR callback when both available."
      },
      "transitions": [
        {
          "trigger_type": "KEYWORD",
          "value": ["summary", "email", "send", "details"],
          "next_node": "email_summary_01",
          "confidence_threshold": 0.7
        },
        {
