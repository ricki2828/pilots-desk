# LLM Configuration
LLM_MODEL=claude-3-5-haiku-20241022
# Alternative models:
# LLM_MODEL=claude-3-5-sonnet-20241022  # More accurate, slower, expensive
# LLM_MODEL=gpt-4o-mini                  # OpenAI alternative
# LLM_MODEL=gpt-4o                       # OpenAI most capable

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# API Keys (provide at least one)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8006

# Logging
LOG_LEVEL=INFO
